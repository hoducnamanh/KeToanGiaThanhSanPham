@model KeToanGiaThanhSanPham.Controllers.ChiPhiNVLViewModel
@{
    ViewData["Title"] = "Tập hợp chi phí nguyên vật liệu";
    var tongChuaTapHop = Model.DanhSachPhieu.Where(p => p.TrangThai == "Chưa tập hợp").Sum(p => p.ThanhTien);
    var tongDaTapHop = Model.DanhSachPhieu.Where(p => p.TrangThai == "Đã tập hợp").Sum(p => p.ThanhTien);
}

<div class="page-container">
    <!-- Header -->
    <div class="page-header">
        <div class="page-header-left">
            <div class="page-icon module-amber">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                </svg>
            </div>
            <div>
                <h1 class="page-title">Tập hợp chi phí NVL</h1>
                <p class="page-subtitle">Nhập liệu và đồng bộ phiếu xuất kho nguyên vật liệu cho sản xuất</p>
            </div>
        </div>
        <div class="page-header-actions">
            <button class="btn-secondary" onclick="toggleModal('modalNhapMoi')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Nhập phiếu mới
            </button>
            <button class="btn-primary" onclick="dongBoPhieu()">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"></polyline><polyline points="1 20 1 14 7 14"></polyline><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path></svg>
                Đồng bộ từ kho
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            @TempData["Success"]
        </div>
    }

    <!-- Thống kê nhanh -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7;color:#d97706;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline></svg>
            </div>
            <div class="stat-info">
                <span class="stat-label">Tổng phiếu xuất</span>
                <span class="stat-value">@Model.DanhSachPhieu.Count</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#dcfce7;color:#16a34a;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            </div>
            <div class="stat-info">
                <span class="stat-label">Đã tập hợp</span>
                <span class="stat-value">@tongDaTapHop.ToString("N0") đ</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef9c3;color:#ca8a04;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
            </div>
            <div class="stat-info">
                <span class="stat-label">Chưa tập hợp</span>
                <span class="stat-value">@tongChuaTapHop.ToString("N0") đ</span>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:#ede9fe;color:#7c3aed;">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
            </div>
            <div class="stat-info">
                <span class="stat-label">Tổng chi phí NVL</span>
                <span class="stat-value">@Model.DanhSachPhieu.Sum(p => p.ThanhTien).ToString("N0") đ</span>
            </div>
        </div>
    </div>

    <!-- Bảng phiếu xuất -->
    <div class="table-card">
        <div class="table-card-header">
            <h3>Danh sách phiếu xuất kho NVL</h3>
            <div class="table-filter">
                <input type="text" placeholder="Tìm kiếm phiếu..." class="search-input" onkeyup="filterTable(this,'nvlTable')" />
            </div>
        </div>

        <form asp-action="TapHop" method="post">
            <div class="table-responsive">
                <table class="data-table" id="nvlTable">
                    <thead>
                        <tr>
                            <th><input type="checkbox" onchange="checkAll(this,'selectedIds')" /></th>
                            <th>Số phiếu</th>
                            <th>Ngày xuất</th>
                            <th>Tên NVL</th>
                            <th>ĐVT</th>
                            <th>Số lượng</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                            <th>Lệnh SX</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var p in Model.DanhSachPhieu)
                        {
                            <tr>
                                <td><input type="checkbox" name="selectedIds" value="@p.Id" @(p.TrangThai == "Đã tập hợp" ? "disabled" : "") /></td>
                                <td><strong>@p.SoPhieu</strong></td>
                                <td>@p.NgayXuat.ToString("dd/MM/yyyy")</td>
                                <td>@p.TenNVL</td>
                                <td>@p.DonVi</td>
                                <td class="text-right">@p.SoLuong.ToString("N0")</td>
                                <td class="text-right">@p.DonGia.ToString("N0")</td>
                                <td class="text-right"><strong>@p.ThanhTien.ToString("N0")</strong></td>
                                <td><span class="badge-lsx">@p.LenhSanXuat</span></td>
                                <td>
                                    @if (p.TrangThai == "Đã tập hợp")
                                    {
                                        <span class="badge-success">✓ Đã tập hợp</span>
                                    }
                                    else
                                    {
                                        <span class="badge-warning">⏳ Chưa tập hợp</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-total">
                            <td colspan="7"><strong>TỔNG CỘNG</strong></td>
                            <td class="text-right"><strong>@Model.DanhSachPhieu.Sum(p => p.ThanhTien).ToString("N0") đ</strong></td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="table-actions">
                <button type="submit" class="btn-primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    Tập hợp chi phí đã chọn
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal nhập mới -->
<div id="modalNhapMoi" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Nhập phiếu xuất kho NVL mới</h3>
            <button class="modal-close" onclick="toggleModal('modalNhapMoi')">✕</button>
        </div>
        <form asp-action="NhapMoi" method="post">
            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Số phiếu</label>
                        <input type="text" name="SoPhieu" class="form-control" required placeholder="VD: PX004" />
                    </div>
                    <div class="form-group">
                        <label>Ngày xuất</label>
                        <input type="date" name="NgayXuat" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="form-group">
                        <label>Tên NVL</label>
                        <input type="text" name="TenNVL" class="form-control" required placeholder="Tên nguyên vật liệu" />
                    </div>
                    <div class="form-group">
                        <label>Đơn vị tính</label>
                        <select name="DonVi" class="form-control">
                            <option>kg</option>
                            <option>lít</option>
                            <option>cái</option>
                            <option>m</option>
                            <option>m²</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Số lượng</label>
                        <input type="number" name="SoLuong" class="form-control" required min="0" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label>Đơn giá (đ)</label>
                        <input type="number" name="DonGia" class="form-control" required min="0" />
                    </div>
                    <div class="form-group form-group-full">
                        <label>Lệnh sản xuất</label>
                        <input type="text" name="LenhSanXuat" class="form-control" placeholder="VD: LSX-2025-003" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="toggleModal('modalNhapMoi')">Hủy</button>
                <button type="submit" class="btn-primary">Lưu phiếu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModal(id) {
            var m = document.getElementById(id);
            m.style.display = m.style.display === 'none' ? 'flex' : 'none';
        }
        function checkAll(cb, name) {
            document.querySelectorAll('input[name="'+name+'"]:not(:disabled)').forEach(function(c){ c.checked = cb.checked; });
        }
        function filterTable(input, tableId) {
            var val = input.value.toLowerCase();
            document.querySelectorAll('#'+tableId+' tbody tr').forEach(function(row){
                row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        }
        function dongBoPhieu() { alert('Tính năng đồng bộ từ hệ thống kho đang được phát triển!'); }
    </script>
}