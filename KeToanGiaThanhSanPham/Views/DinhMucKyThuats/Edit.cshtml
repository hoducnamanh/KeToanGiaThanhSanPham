@model KeToanGiaThanhSanPham.Models.ViewModels.DinhMucKyThuat.DinhMucEditViewModel

@{
    ViewData["Title"] = "Sửa định mức";
}

<div class="container mt-3">
    <h2>Chỉnh sửa dòng định mức</h2>
    <hr />

    <div class="row">
        <div class="col-md-5">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="SanPhamId" />

                <div class="mb-3">
                    <label asp-for="TenNguyenVatLieu" class="form-label fw-bold"></label>
                    <input asp-for="TenNguyenVatLieu" class="form-control bg-secondary text-white" readonly />
                </div>

                <div class="mb-3">
                    <label asp-for="SoLuong" class="form-label fw-bold"></label>
                    <input asp-for="SoLuong" type="number" step="0.00001" class="form-control" required />
                    <span asp-validation-for="SoLuong" class="text-danger"></span>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary">Cập nhật dữ liệu</button>
                    <a href="/DinhMucKyThuats/Index?sanPhamId=@Model.SanPhamId" class="btn btn-secondary">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}