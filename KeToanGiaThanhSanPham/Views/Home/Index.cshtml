@{
    ViewData["Title"] = "Trang chủ";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="hero-bg-grid"></div>
    <div class="container hero-content">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <div class="hero-badge">
                    <span class="badge-dot"></span>
                    Hệ thống quản lý kế toán
                </div>
                <h1 class="hero-title">Kế Toán<br><span class="accent-text">Giá Thành</span><br>Sản Phẩm</h1>
                <p class="hero-subtitle">Giải pháp quản lý chi phí sản xuất, tính giá thành sản phẩm và kiểm soát nguyên vật liệu toàn diện cho doanh nghiệp.</p>
                <div class="hero-actions">
                    <a asp-controller="SanPhams" asp-action="Index" class="btn-hero-primary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                        Vào hệ thống
                    </a>
                    <a asp-controller="SanPhams" asp-action="Create" class="btn-hero-secondary">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                        Thêm mới
                    </a>
                </div>
            </div>
            <div class="col-lg-5 d-none d-lg-block">
                <div class="hero-graphic">
                    <div class="stat-card stat-card-1">
                        <div class="stat-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                        </div>
                        <div>
                            <div class="stat-label">Sản phẩm</div>
                            <div class="stat-value">Quản lý</div>
                        </div>
                    </div>
                    <div class="stat-card stat-card-2">
                        <div class="stat-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                        </div>
                        <div>
                            <div class="stat-label">Nguyên vật liệu</div>
                            <div class="stat-value">Theo dõi</div>
                        </div>
                    </div>
                    <div class="stat-card stat-card-3">
                        <div class="stat-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                        </div>
                        <div>
                            <div class="stat-label">Phân xưởng</div>
                            <div class="stat-value">Kiểm soát</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="stats-bar">
    <div class="container">
        <div class="row g-0">
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path></svg>
                    <div>
                        <div class="stat-item-label">Sản phẩm</div>
                        <div class="stat-item-desc">Quản lý danh mục</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                    <div>
                        <div class="stat-item-label">Định mức KT</div>
                        <div class="stat-item-desc">Kỹ thuật sản xuất</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
                    <div>
                        <div class="stat-item-label">Phân xưởng</div>
                        <div class="stat-item-desc">Quản lý khu vực</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-item">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path></svg>
                    <div>
                        <div class="stat-item-label">Nguyên vật liệu</div>
                        <div class="stat-item-desc">Kiểm soát tồn kho</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Quick Access Cards -->
<section class="quick-access py-5">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Truy cập nhanh</h2>
            <p class="section-desc">Chọn chức năng để bắt đầu quản lý</p>
        </div>
        <div class="row g-4">
            <div class="col-md-6 col-xl-3">
                <a asp-controller="SanPhams" asp-action="Index" class="module-card">
                    <div class="module-icon-wrap module-blue">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                    </div>
                    <div class="module-info">
                        <h3>Sản phẩm</h3>
                        <p>Quản lý danh mục và giá thành sản phẩm sản xuất</p>
                    </div>
                    <div class="module-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-3">
                <a asp-controller="NguyenVatLieus" asp-action="Index" class="module-card">
                    <div class="module-icon-wrap module-amber">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
                    </div>
                    <div class="module-info">
                        <h3>Nguyên vật liệu</h3>
                        <p>Theo dõi và kiểm soát nguyên vật liệu đầu vào</p>
                    </div>
                    <div class="module-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-3">
                <a asp-controller="PhanXuongs" asp-action="Index" class="module-card">
                    <div class="module-icon-wrap module-teal">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                    </div>
                    <div class="module-info">
                        <h3>Phân xưởng</h3>
                        <p>Quản lý các khu vực và phân xưởng sản xuất</p>
                    </div>
                    <div class="module-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </div>
                </a>
            </div>
            <div class="col-md-6 col-xl-3">
                <a asp-controller="DinhMucKyThuats" asp-action="Index" class="module-card">
                    <div class="module-icon-wrap module-violet">
                        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                    </div>
                    <div class="module-info">
                        <h3>Định mức kỹ thuật</h3>
                        <p>Thiết lập và quản lý định mức tiêu hao NVL</p>
                    </div>
                    <div class="module-arrow">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </div>
                </a>
            </div>
        </div>
    </div>
</section>