@model KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.KyTinhGiaThanhViewModel
@{
    ViewData["Title"] = "Tính Giá Thành";
}

<div class="container-fluid px-4 py-4">
    <div class="page-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="page-icon" style="background: linear-gradient(135deg,#6366f1,#8b5cf6)">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M12 6v6l4 2"></path>
                </svg>
            </div>
            <div>
                <h1 class="page-title mb-0">Tính Giá Thành Sản Phẩm</h1>
                <p class="text-muted small mb-0">Chạy thuật toán tính giá thành theo kỳ kế toán</p>
            </div>
        </div>
    </div>

    <!-- Stepper -->
    <div class="gthanh-stepper mb-4">
        <div class="gthanh-step active">
            <div class="step-circle">1</div>
            <span>Khai báo kỳ</span>
        </div>
        <div class="step-line"></div>
        <div class="gthanh-step">
            <div class="step-circle">2</div>
            <span>Đánh giá WIP</span>
        </div>
        <div class="step-line"></div>
        <div class="gthanh-step">
            <div class="step-circle">3</div>
            <span>Phân bổ chi phí</span>
        </div>
        <div class="step-line"></div>
        <div class="gthanh-step">
            <div class="step-circle">4</div>
            <span>Kết quả</span>
        </div>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card-modern">
                <div class="card-modern-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                    </svg>
                    Bước 1 — Khai báo kỳ tính giá thành
                </div>
                <div class="card-modern-body">
                    <form asp-action="KhaiBaoKy" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-4">
                            <label class="form-label fw-semibold">Loại kỳ tính</label>
                            <div class="ky-tinh-selector">
                                <label class="ky-option @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Thang ? "selected" : "")">
                                    <input type="radio" name="LoaiKy" value="1"
                                           @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Thang ? "checked" : "")
                                           onchange="toggleKyOptions()" />
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"></rect><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                    Tháng
                                </label>
                                <label class="ky-option @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Quy ? "selected" : "")">
                                    <input type="radio" name="LoaiKy" value="2"
                                           @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Quy ? "checked" : "")
                                           onchange="toggleKyOptions()" />
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline></svg>
                                    Quý
                                </label>
                                <label class="ky-option @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Nam ? "selected" : "")">
                                    <input type="radio" name="LoaiKy" value="3"
                                           @(Model.LoaiKy == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.LoaiKy.Nam ? "checked" : "")
                                           onchange="toggleKyOptions()" />
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                    Năm
                                </label>
                            </div>
                        </div>

                        <div class="row g-3">
                            <div class="col" id="thangGroup">
                                <label asp-for="Thang" class="form-label fw-semibold"></label>
                                <select asp-for="Thang" class="form-select">
                                    @for (int i = 1; i <= 12; i++)
                                    {
                                        <option value="@i" selected="@(Model.Thang == i ? "selected" : null)">Tháng @i</option>
                                    }
                                </select>
                                <span asp-validation-for="Thang" class="text-danger small"></span>
                            </div>
                            <div class="col d-none" id="quyGroup">
                                <label asp-for="Quy" class="form-label fw-semibold"></label>
                                <select asp-for="Quy" class="form-select">
                                    <option value="1">Quý I (T1-T3)</option>
                                    <option value="2">Quý II (T4-T6)</option>
                                    <option value="3">Quý III (T7-T9)</option>
                                    <option value="4">Quý IV (T10-T12)</option>
                                </select>
                                <span asp-validation-for="Quy" class="text-danger small"></span>
                            </div>
                            <div class="col">
                                <label asp-for="Nam" class="form-label fw-semibold"></label>
                                <input asp-for="Nam" class="form-control" type="number" min="2000" max="2100" />
                                <span asp-validation-for="Nam" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="mt-4 d-flex justify-content-end">
                            <button type="submit" class="btn-primary-modern">
                                Tiếp theo
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"></polyline></svg>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function toggleKyOptions() {
    const val = document.querySelector('input[name="LoaiKy"]:checked')?.value;
    document.getElementById('thangGroup').classList.toggle('d-none', val !== '1');
    document.getElementById('quyGroup').classList.toggle('d-none', val !== '2');
    document.querySelectorAll('.ky-option').forEach(el => {
        el.classList.toggle('selected', el.querySelector('input').checked);
    });
}
document.addEventListener('DOMContentLoaded', toggleKyOptions);
</script>
}