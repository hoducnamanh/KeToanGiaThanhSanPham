@model KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.PhanBoChiPhiViewModel
@{
    ViewData["Title"] = "Phân Bổ Chi Phí Chung";
}

<div class="container-fluid px-4 py-4">
    <div class="page-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <div class="page-icon" style="background: linear-gradient(135deg,#10b981,#059669)">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
            </div>
            <div>
                <h1 class="page-title mb-0">Tiêu Thức Phân Bổ & Chi Phí SXC</h1>
                <p class="text-muted small mb-0">Nhập chi phí sản xuất chung và chọn cách phân bổ</p>
            </div>
        </div>
    </div>

    <!-- Stepper -->
    <div class="gthanh-stepper mb-4">
        <div class="gthanh-step done"><div class="step-circle">✓</div><span>Khai báo kỳ</span></div>
        <div class="step-line done"></div>
        <div class="gthanh-step done"><div class="step-circle">✓</div><span>Đánh giá WIP</span></div>
        <div class="step-line done"></div>
        <div class="gthanh-step active"><div class="step-circle">3</div><span>Phân bổ chi phí</span></div>
        <div class="step-line"></div>
        <div class="gthanh-step"><div class="step-circle">4</div><span>Kết quả</span></div>
    </div>

    <form asp-action="NhapPhanBoChiPhi" method="post">
        @Html.AntiForgeryToken()

        <!-- Hidden: KyTinh -->
        <input type="hidden" name="KyTinh.LoaiKy" value="@((int)Model.KyTinh.LoaiKy)" />
        <input type="hidden" name="KyTinh.Thang" value="@Model.KyTinh.Thang" />
        <input type="hidden" name="KyTinh.Quy" value="@Model.KyTinh.Quy" />
        <input type="hidden" name="KyTinh.Nam" value="@Model.KyTinh.Nam" />

        <!-- Hidden: WIP -->
        <input type="hidden" name="WIPData.PhuongPhap" value="@((int)Model.WIPData.PhuongPhap)" />
        @for (int i = 0; i < Model.WIPData.DanhSachWIP.Count; i++)
        {
            <input type="hidden" name="WIPData.DanhSachWIP[@i].SanPhamId" value="@Model.WIPData.DanhSachWIP[i].SanPhamId" />
            <input type="hidden" name="WIPData.DanhSachWIP[@i].MaSanPham" value="@Model.WIPData.DanhSachWIP[i].MaSanPham" />
            <input type="hidden" name="WIPData.DanhSachWIP[@i].TenSanPham" value="@Model.WIPData.DanhSachWIP[i].TenSanPham" />
            <input type="hidden" name="WIPData.DanhSachWIP[@i].DonViTinh" value="@Model.WIPData.DanhSachWIP[i].DonViTinh" />
            <input type="hidden" name="WIPData.DanhSachWIP[@i].SoLuongDoDang" value="@Model.WIPData.DanhSachWIP[i].SoLuongDoDang" />
            <input type="hidden" name="WIPData.DanhSachWIP[@i].TyLeHoanThanh" value="@Model.WIPData.DanhSachWIP[i].TyLeHoanThanh" />
        }

        <div class="row g-4">
            <div class="col-md-5">
                <!-- Tiêu thức phân bổ -->
                <div class="card-modern mb-4">
                    <div class="card-modern-header">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline>
                        </svg>
                        Tiêu thức phân bổ chi phí chung
                    </div>
                    <div class="card-modern-body">
                        <div class="tieuthu-list">
                            <label class="tieuthu-item @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoNVLTrucTiep ? "selected" : "")">
                                <input type="radio" name="TieuThuc" value="1"
                                       @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoNVLTrucTiep ? "checked" : "")
                                       onchange="onTieuThucChange(this)" />
                                <div class="tieuthu-icon" style="background:#ede9fe;color:#7c3aed">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path></svg>
                                </div>
                                <div>
                                    <div class="fw-semibold">Theo tỷ lệ NVL trực tiếp</div>
                                    <div class="text-muted small">Phân bổ theo giá trị NVL từng SP</div>
                                </div>
                            </label>
                            <label class="tieuthu-item @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoGioCong ? "selected" : "")">
                                <input type="radio" name="TieuThuc" value="2"
                                       @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoGioCong ? "checked" : "")
                                       onchange="onTieuThucChange(this)" />
                                <div class="tieuthu-icon" style="background:#d1fae5;color:#059669">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
                                </div>
                                <div>
                                    <div class="fw-semibold">Theo giờ công lao động</div>
                                    <div class="text-muted small">Phân bổ theo số giờ công mỗi SP</div>
                                </div>
                            </label>
                            <label class="tieuthu-item @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoSoLuongSanXuat ? "selected" : "")">
                                <input type="radio" name="TieuThuc" value="3"
                                       @(Model.TieuThuc == KeToanGiaThanhSanPham.Models.ViewModels.TinhGiaThanh.TieuThucPhanBo.TheoSoLuongSanXuat ? "checked" : "")
                                       onchange="onTieuThucChange(this)" />
                                <div class="tieuthu-icon" style="background:#fef3c7;color:#d97706">
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"></line><line x1="8" y1="12" x2="21" y2="12"></line><line x1="8" y1="18" x2="21" y2="18"></line><line x1="3" y1="6" x2="3.01" y2="6"></line><line x1="3" y1="12" x2="3.01" y2="12"></line><line x1="3" y1="18" x2="3.01" y2="18"></line></svg>
                                </div>
                                <div>
                                    <div class="fw-semibold">Theo số lượng sản xuất</div>
                                    <div class="text-muted small">Phân bổ đều theo số lượng SX</div>
                                </div>
                            </label>
                        </div>

                        <!-- Nhập giờ công / SL khi cần -->
                        <div id="chiTietTieuThucPanel" class="mt-3 d-none">
                            <hr />
                            <p class="small fw-semibold text-muted mb-2" id="tieuThucLabel">Chi tiết tiêu thức</p>
                            <table class="table table-sm">
                                <thead><tr><th>Sản phẩm</th><th id="ttHeader">Giá trị</th></tr></thead>
                                <tbody>
                                    @for (int i = 0; i < Model.ChiTietTieuThuc.Count; i++)
                                    {
                                        <tr>
                                            <td>
                                                <input type="hidden" name="ChiTietTieuThuc[@i].SanPhamId" value="@Model.ChiTietTieuThuc[i].SanPhamId" />
                                                <input type="hidden" name="ChiTietTieuThuc[@i].TenSanPham" value="@Model.ChiTietTieuThuc[i].TenSanPham" />
                                                <span class="small">@Model.ChiTietTieuThuc[i].TenSanPham</span>
                                            </td>
                                            <td>
                                                <input type="number" class="form-control form-control-sm gio-cong-input"
                                                       name="ChiTietTieuThuc[@i].GioCongMoiSP"
                                                       value="@Model.ChiTietTieuThuc[i].GioCongMoiSP"
                                                       min="0" step="0.01" />
                                                <input type="number" class="form-control form-control-sm sl-sx-input d-none"
                                                       name="ChiTietTieuThuc[@i].SoLuongSanXuat"
                                                       value="@Model.ChiTietTieuThuc[i].SoLuongSanXuat"
                                                       min="0" step="1" />
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                <!-- Chi phí SXC -->
                <div class="card-modern">
                    <div class="card-modern-header d-flex justify-content-between align-items-center">
                        <span>
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <line x1="12" y1="1" x2="12" y2="23"></line>
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                            </svg>
                            Chi phí sản xuất chung (SXC)
                        </span>
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="themDong()">+ Thêm khoản</button>
                    </div>
                    <div class="card-modern-body p-0">
                        <table class="table mb-0" id="chiPhiTable">
                            <thead class="table-header-modern">
                                <tr>
                                    <th>Khoản chi phí</th>
                                    <th style="width:180px">Số tiền (VNĐ)</th>
                                    <th style="width:50px"></th>
                                </tr>
                            </thead>
                            <tbody id="chiPhiBody">
                                @for (int i = 0; i < Model.DanhSachChiPhi.Count; i++)
                                {
                                    <tr>
                                        <td>
                                            <input type="text" class="form-control form-control-sm"
                                                   name="DanhSachChiPhi[@i].TenChiPhi"
                                                   value="@Model.DanhSachChiPhi[i].TenChiPhi" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm chi-phi-input"
                                                   name="DanhSachChiPhi[@i].SoTien"
                                                   value="@Model.DanhSachChiPhi[i].SoTien"
                                                   min="0" step="1000" onchange="updateTong()" />
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-ghost-danger" onclick="xoaDong(this)">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="table-active fw-bold">
                                    <td>Tổng chi phí SXC</td>
                                    <td id="tongChiPhi" class="text-end text-success">0 ₫</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4 d-flex justify-content-between">
            <a asp-action="Index" class="btn-outline-modern">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"></polyline></svg>
                Quay lại đầu
            </a>
            <button type="submit" class="btn-success-modern">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 4 12 14.01 9 11.01"></polyline><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"></path></svg>
                Chạy Tính Giá Thành
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let rowCount = @Model.DanhSachChiPhi.Count;

        function themDong() {
            const tbody = document.getElementById('chiPhiBody');
            const i = rowCount++;
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td><input type="text" class="form-control form-control-sm" name="DanhSachChiPhi[${i}].TenChiPhi" placeholder="Nhập khoản chi phí" /></td>
                <td><input type="number" class="form-control form-control-sm chi-phi-input" name="DanhSachChiPhi[${i}].SoTien" value="0" min="0" step="1000" onchange="updateTong()" /></td>
                <td><button type="button" class="btn btn-sm btn-ghost-danger" onclick="xoaDong(this)">✕</button></td>`;
            tbody.appendChild(tr);
        }

        function xoaDong(btn) {
            btn.closest('tr').remove();
            updateTong();
        }

        function updateTong() {
            const inputs = document.querySelectorAll('.chi-phi-input');
            let tong = 0;
            inputs.forEach(inp => tong += parseFloat(inp.value) || 0);
            document.getElementById('tongChiPhi').textContent = tong.toLocaleString('vi-VN') + ' ₫';
        }

        function onTieuThucChange(radio) {
            document.querySelectorAll('.tieuthu-item').forEach(el => {
                el.classList.toggle('selected', el.querySelector('input').checked);
            });
            const val = radio.value;
            const panel = document.getElementById('chiTietTieuThucPanel');
            if (val === '2' || val === '3') {
                panel.classList.remove('d-none');
                document.getElementById('ttHeader').textContent = val === '2' ? 'Giờ công / SP' : 'SL sản xuất';
                document.getElementById('tieuThucLabel').textContent = val === '2' ? 'Giờ công lao động mỗi sản phẩm' : 'Số lượng sản xuất';
                document.querySelectorAll('.gio-cong-input').forEach(el => el.classList.toggle('d-none', val !== '2'));
                document.querySelectorAll('.sl-sx-input').forEach(el => el.classList.toggle('d-none', val !== '3'));
            } else {
                panel.classList.add('d-none');
            }
        }

        document.addEventListener('DOMContentLoaded', () => {
            updateTong();
            const checked = document.querySelector('input[name="TieuThuc"]:checked');
            if (checked) onTieuThucChange(checked);
        });
    </script>
}