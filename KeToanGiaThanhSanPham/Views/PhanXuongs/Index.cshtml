@model IEnumerable<KeToanGiaThanhSanPham.Models.PhanXuong>

@{
    ViewData["Title"] = "Danh mục phân xưởng";
}

<div class="container-fluid px-4 py-4">
    <h1 class="mb-4">DANH MỤC PHÂN XƯỞNG</h1>

    <div class="row mb-4">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="input-group">
                <input type="text" name="searchString" class="form-control" 
                       placeholder="Tìm kiếm mã hoặc tên phân xưởng..." 
                       value="@ViewData["CurrentFilter"]" />
                <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                <a asp-action="Index" class="btn btn-secondary">Xóa bộ lọc</a>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">+ Thêm phân xưởng mới</a>
        </div>
    </div>

    @if (Model.Count() > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["MaPXSort"]" 
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @Html.DisplayNameFor(model => model.FirstOrDefault().MaPhanXuong)
                                @if (ViewData["CurrentSort"]?.ToString() == "maPX_desc")
                                {
                                    <i class="bi bi-sort-down"></i>
                                }
                                else if (String.IsNullOrEmpty(ViewData["CurrentSort"]?.ToString()))
                                {
                                    <i class="bi bi-sort-up"></i>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["TenPXSort"]" 
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @Html.DisplayNameFor(model => model.FirstOrDefault().TenPhanXuong)
                                @if (ViewData["CurrentSort"]?.ToString() == "TenPX_desc")
                                {
                                    <i class="bi bi-sort-down"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "TenPX")
                                {
                                    <i class="bi bi-sort-up"></i>
                                }
                            </a>
                        </th>
                        <th style="width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.MaPhanXuong)</td>
                            <td>@Html.DisplayFor(modelItem => item.TenPhanXuong)</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Không tìm thấy phân xưởng phù hợp. <a asp-action="Index">Xóa bộ lọc</a>
        </div>
    }
</div>
