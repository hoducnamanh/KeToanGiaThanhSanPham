@model IEnumerable<KeToanGiaThanhSanPham.Models.NguyenVatLieu>

@{
    ViewData["Title"] = "Danh mục nguyên vật liệu";
}

<div class="container-fluid px-4 py-4">
    <h1 class="mb-4">DANH MỤC NGUYÊN VẬT LIỆU</h1>

    <div class="row mb-4">
        <div class="col-md-8">
            <form asp-action="Index" method="get" class="input-group">
                <input type="text" name="searchString" class="form-control" 
                       placeholder="Tìm kiếm mã, tên nguyên vật liệu hoặc đơn vị tính..." 
                       value="@ViewData["CurrentFilter"]" />
                <button class="btn btn-primary" type="submit">Tìm kiếm</button>
                <a asp-action="Index" class="btn btn-secondary">Xóa bộ lọc</a>
            </form>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="Create" class="btn btn-success">+ Thêm nguyên vật liệu mới</a>
        </div>
    </div>

    @if (Model.Count() > 0)
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["MaNVLSort"]" 
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @Html.DisplayNameFor(model => model.FirstOrDefault().MaNguyenVatLieu)
                                @if (ViewData["CurrentSort"]?.ToString() == "maNVL_desc")
                                {
                                    <i class="bi bi-sort-down"></i>
                                }
                                else if (String.IsNullOrEmpty(ViewData["CurrentSort"]?.ToString()))
                                {
                                    <i class="bi bi-sort-up"></i>
                                }
                            </a>
                        </th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["TenNVLSort"]" 
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @Html.DisplayNameFor(model => model.FirstOrDefault().TenNguyenVatLieu)
                                @if (ViewData["CurrentSort"]?.ToString() == "TenNVL_desc")
                                {
                                    <i class="bi bi-sort-down"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "TenNVL")
                                {
                                    <i class="bi bi-sort-up"></i>
                                }
                            </a>
                        </th>
                        <th>@Html.DisplayNameFor(model => model.FirstOrDefault().DonViTinh)</th>
                        <th>
                            <a asp-action="Index" asp-route-sortOrder="@ViewData["DonGiaSort"]" 
                               asp-route-searchString="@ViewData["CurrentFilter"]">
                                @Html.DisplayNameFor(model => model.FirstOrDefault().DonGia)
                                @if (ViewData["CurrentSort"]?.ToString() == "DonGia_desc")
                                {
                                    <i class="bi bi-sort-down"></i>
                                }
                                else if (ViewData["CurrentSort"]?.ToString() == "DonGia")
                                {
                                    <i class="bi bi-sort-up"></i>
                                }
                            </a>
                        </th>
                        <th style="width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.MaNguyenVatLieu)</td>
                            <td>@Html.DisplayFor(modelItem => item.TenNguyenVatLieu)</td>
                            <td>@Html.DisplayFor(modelItem => item.DonViTinh)</td>
                            <td>@Html.DisplayFor(modelItem => item.DonGia)</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Chi tiết</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Xóa</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            Không tìm thấy nguyên vật liệu phù hợp. <a asp-action="Index">Xóa bộ lọc</a>
        </div>
    }
</div>
