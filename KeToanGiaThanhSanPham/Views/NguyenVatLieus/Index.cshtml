@model IEnumerable<KeToanGiaThanhSanPham.Models.NguyenVatLieu>

@{
    ViewData["Title"] = "Danh mục nguyên vật liệu";
}

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-end border-bottom pb-3 mb-4 flex-wrap gap-2">
        <div>
            <small class="text-uppercase text-muted fw-bold tracking-wider" style="font-size: 0.75rem; letter-spacing: 0.1em;">Danh mục</small>
            <h1 class="h3 mb-0 text-uppercase fw-bold text-dark">Nguyên vật liệu</h1>
        </div>
        <a asp-action="Create" class="btn btn-primary text-uppercase fw-semibold shadow-sm">
            + Thêm NVL
        </a>
    </div>

    <div class="row g-3 mb-4 align-items-center">
        <div class="col-12 col-md-6 col-lg-5">
            <form asp-action="Index" method="get" class="input-group shadow-sm">
                <input type="text" name="searchString" class="form-control"
                       placeholder="Tìm mã, tên NVL hoặc đơn vị tính..."
                       value="@ViewData["CurrentFilter"]" />
                <button class="btn btn-dark text-uppercase fw-semibold" type="submit">Tìm</button>
            </form>
        </div>
        <div class="col-12 col-md-6 col-lg-7">
            @if (!string.IsNullOrEmpty(ViewData["CurrentFilter"]?.ToString()))
            {
                <a asp-action="Index" class="btn btn-outline-secondary text-uppercase fw-semibold">
                    Xóa bộ lọc
                </a>
            }
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="card shadow-sm border-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 text-nowrap">
                    <thead class="text-uppercase fs-7 text-white" style="background-color: #0f172a !important;">
                        <tr>
                            <th class="ps-3 py-3" style="font-size: 0.8rem; letter-spacing: 0.05em; background: none !important; color: #ffffff !important;">
                                <a asp-action="Index" asp-route-sortOrder="@ViewData["MaNVLSort"]"
                                   asp-route-searchString="@ViewData["CurrentFilter"]"
                                   class="text-white text-decoration-none d-flex align-items-center">
                                    Mã NVL
                                    <span class="ms-1">
                                        @(ViewData["CurrentSort"]?.ToString() == "maNVL_desc" ? "↓" : string.IsNullOrEmpty(ViewData["CurrentSort"]?.ToString()) ? "↑" : "")
                                    </span>
                                </a>
                            </th>
                            <th class="py-3" style="font-size: 0.8rem; letter-spacing: 0.05em; background: none !important; color: #ffffff !important;">
                                <a asp-action="Index" asp-route-sortOrder="@ViewData["TenNVLSort"]"
                                   asp-route-searchString="@ViewData["CurrentFilter"]"
                                   class="text-white text-decoration-none d-flex align-items-center">
                                    Tên nguyên vật liệu
                                    <span class="ms-1">
                                        @(ViewData["CurrentSort"]?.ToString() == "TenNVL_desc" ? "↓" : ViewData["CurrentSort"]?.ToString() == "TenNVL" ? "↑" : "")
                                    </span>
                                </a>
                            </th>
                            <th class="py-3 text-uppercase" style="font-size: 0.8rem; letter-spacing: 0.05em; background: none !important; color: #cbd5e1 !important;">ĐVT</th>
                            <th class="py-3" style="font-size: 0.8rem; letter-spacing: 0.05em; background: none !important; color: #ffffff !important;">
                                <a asp-action="Index" asp-route-sortOrder="@ViewData["DonGiaSort"]"
                                   asp-route-searchString="@ViewData["CurrentFilter"]"
                                   class="text-white text-decoration-none d-flex align-items-center">
                                    Đơn giá
                                    <span class="ms-1">
                                        @(ViewData["CurrentSort"]?.ToString() == "DonGia_desc" ? "↓" : ViewData["CurrentSort"]?.ToString() == "DonGia" ? "↑" : "")
                                    </span>
                                </a>
                            </th>
                            <th class="pe-3 py-3 text-uppercase text-end" style="font-size: 0.8rem; letter-spacing: 0.05em; width: 200px; background: none !important; color: #cbd5e1 !important;">Hành động</th>
                        </tr>
                    </thead>
                    <tbody class="table-group-divider">
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-bold text-dark font-monospace" style="font-size: 0.85rem;">@item.MaNguyenVatLieu</td>
                                <td>
                                    <span class="fw-bold text-dark">@item.TenNguyenVatLieu</span>
                                </td>
                                <td><span class="badge bg-light text-dark border px-2 py-1.5">@item.DonViTinh</span></td>
                                <td class="font-monospace text-dark fw-bold" style="font-size: 0.85rem;">
                                    @item.DonGia.ToString("N0") ₫
                                </td>
                                <td class="pe-3 text-end">
                                    <div class="d-inline-flex gap-1">
                                        <a asp-action="Details" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-info text-uppercase fw-bold" style="font-size: 0.7rem;">
                                            Xem
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-warning text-uppercase fw-bold text-dark" style="font-size: 0.7rem;">
                                            Sửa
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-outline-danger text-uppercase fw-bold" style="font-size: 0.7rem;">
                                            Xóa
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer bg-light border-top py-3 ps-3">
                <small class="text-uppercase fw-bold text-muted" style="letter-spacing: 0.05em;">
                    Tổng cộng: <span class="text-dark font-monospace fw-bold">@Model.Count()</span> nguyên vật liệu
                </small>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-warning text-center p-5 shadow-sm border-0" role="alert">
            <span class="fw-semibold text-uppercase d-block mb-3" style="letter-spacing: 0.05em;">Không tìm thấy nguyên vật liệu phù hợp.</span>
            <a asp-action="Index" class="btn btn-sm btn-dark text-uppercase fw-semibold px-3">Xóa bộ lọc</a>
        </div>
    }
</div>