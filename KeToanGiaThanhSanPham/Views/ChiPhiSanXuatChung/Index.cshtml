@model List<KeToanGiaThanhSanPham.Controllers.ChiPhiSXChung>
@{
    ViewData["Title"] = "Tập hợp chi phí sản xuất chung";
    var loaiChiPhi = new[] { "Khấu hao máy móc", "Điện sản xuất", "Nước sản xuất", "Thuê xưởng", "Lương quản lý PX", "Sửa chữa thiết bị", "Chi phí khác" };
}

<div class="page-container">
    <div class="page-header">
        <div class="page-header-left">
            <div class="page-icon module-teal">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="7" width="20" height="14" rx="2"></rect>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
                </svg>
            </div>
            <div>
                <h1 class="page-title">Tập hợp chi phí SX chung</h1>
                <p class="page-subtitle">Ghi nhận khấu hao, điện nước, thuê xưởng và lương quản lý phân xưởng</p>
            </div>
        </div>
        <div class="page-header-actions">
            <button class="btn-secondary" onclick="toggleModal('modalSXC')">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Thêm khoản chi phí
            </button>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert-success">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
            @TempData["Success"]
        </div>
    }

    <!-- Phân tích theo loại -->
    <div class="stats-grid">
        @{
            var nhomLoai = new[] {
                new { Ten="Khấu hao", Icon="📦", Color="#dbeafe", TextColor="#2563eb" },
                new { Ten="Điện & Nước", Icon="⚡", Color="#fef9c3", TextColor="#ca8a04" },
                new { Ten="Thuê xưởng", Icon="🏭", Color="#dcfce7", TextColor="#16a34a" },
                new { Ten="Lương QLPX", Icon="👷", Color="#ede9fe", TextColor="#7c3aed" }
                };
        }
        @foreach (var nhom in nhomLoai)
        {
            <div class="stat-card">
                <div class="stat-icon" style="background:@nhom.Color;color:@nhom.TextColor;font-size:18px;">@nhom.Icon</div>
                <div class="stat-info">
                    <span class="stat-label">@nhom.Ten</span>
                    <span class="stat-value">@Model.Where(x => x.LoaiChiPhi.Contains(nhom.Ten.Split('&')[0].Trim())).Sum(x => x.SoTien).ToString("N0") đ</span>
                </div>
            </div>
        }
    </div>

    <div class="table-card">
        <div class="table-card-header">
            <h3>Danh sách chi phí sản xuất chung</h3>
            <div style="display:flex;gap:8px;align-items:center;">
                <span style="font-size:13px;color:#64748b;">Tổng: <strong>@Model.Sum(x => x.SoTien).ToString("N0") đ</strong></span>
                <input type="text" placeholder="Tìm kiếm..." class="search-input" onkeyup="filterTable(this,'sxcTable')" />
            </div>
        </div>
        <form asp-action="GhiNhan" method="post">
            <div class="table-responsive">
                <table class="data-table" id="sxcTable">
                    <thead>
                        <tr>
                            <th><input type="checkbox" onchange="checkAll(this,'selectedIds')" /></th>
                            <th>Loại chi phí</th>
                            <th>Mô tả</th>
                            <th>Từ ngày</th>
                            <th>Đến ngày</th>
                            <th>Số tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var cp in Model)
                        {
                            <tr>
                                <td><input type="checkbox" name="selectedIds" value="@cp.Id" @(cp.TrangThai == "Đã ghi nhận" ? "disabled" : "") /></td>
                                <td>
                                    <span class="loai-chip">@cp.LoaiChiPhi</span>
                                </td>
                                <td>@cp.MoTa</td>
                                <td>@cp.TuNgay.ToString("dd/MM/yyyy")</td>
                                <td>@cp.DenNgay.ToString("dd/MM/yyyy")</td>
                                <td class="text-right"><strong>@cp.SoTien.ToString("N0")</strong></td>
                                <td>
                                    @if (cp.TrangThai == "Đã ghi nhận")
                                    {
                                        <span class="badge-success">✓ Đã ghi nhận</span>
                                    }
                                    else
                                    {

                                        <span class="badge-warning">⏳ Chưa ghi nhận</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr class="table-total">
                            <td colspan="5"><strong>TỔNG CHI PHÍ SX CHUNG</strong></td>
                            <td class="text-right"><strong>@Model.Sum(x => x.SoTien).ToString("N0") đ</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="table-actions">
                <button type="submit" class="btn-primary">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    Ghi nhận chi phí đã chọn
                </button>
            </div>
        </form>
    </div>
</div>

<div id="modalSXC" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Thêm khoản chi phí SX chung</h3>
            <button class="modal-close" onclick="toggleModal('modalSXC')">✕</button>
        </div>
        <form asp-action="NhapMoi" method="post">
            <div class="modal-body">
                <div class="form-grid">
                    <div class="form-group form-group-full">
                        <label>Loại chi phí</label>
                        <select name="LoaiChiPhi" class="form-control">
                            @foreach (var lcp in loaiChiPhi)
                            {
                                <option>@lcp</option>
                            }
                        </select>
                    </div>
                    <div class="form-group form-group-full">
                        <label>Mô tả chi tiết</label>
                        <input type="text" name="MoTa" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Từ ngày</label>
                        <input type="date" name="TuNgay" class="form-control" required />
                    </div>
                    <div class="form-group">
                        <label>Đến ngày</label>
                        <input type="date" name="DenNgay" class="form-control" required />
                    </div>
                    <div class="form-group form-group-full">
                        <label>Số tiền (đ)</label>
                        <input type="number" name="SoTien" class="form-control" required min="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-secondary" onclick="toggleModal('modalSXC')">Hủy</button>
                <button type="submit" class="btn-primary">Lưu</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModal(id) {
            var m = document.getElementById(id);
            m.style.display = m.style.display === 'none' ? 'flex' : 'none';
        }
        function checkAll(cb, name) {
            document.querySelectorAll('input[name="'+name+'"]:not(:disabled)').forEach(function(c){ c.checked = cb.checked; });
        }
        function filterTable(input, tableId) {
            var val = input.value.toLowerCase();
            document.querySelectorAll('#'+tableId+' tbody tr').forEach(function(row){
                row.style.display = row.textContent.toLowerCase().includes(val) ? '' : 'none';
            });
        }
    </script>
}