<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Kế Toán Giá Thành</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/KeToanGiaThanhSanPham.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="main-navbar">
            <div class="container-fluid px-4">
                <div class="navbar-inner">
                    <a class="brand-link" asp-area="" asp-controller="Home" asp-action="Index">
                        <div class="brand-icon">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                        </div>
                        <div class="brand-text">
                            <span class="brand-name">KeToan</span><span class="brand-accent">GiaThanh</span>
                        </div>
                    </a>

                    <ul class="nav-links d-none d-md-flex">
                        <li>
                            <a class="nav-link-item" asp-area="" asp-controller="Home" asp-action="Index">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                                Trang chủ
                            </a>
                        </li>
                        <li class="nav-dropdown-wrapper">
                            <button class="nav-link-item nav-dropdown-toggle" type="button" aria-expanded="false" aria-haspopup="true">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect></svg>
                                Danh mục
                                <svg class="dropdown-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </button>
                            <div class="nav-dropdown-menu">
                                <div class="nav-dropdown-inner">
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="SanPhams" asp-action="Index">
                                        <div class="nav-dropdown-icon module-blue">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Sản phẩm</span>
                                            <span class="nav-dropdown-desc">Quản lý danh mục sản phẩm</span>
                                        </div>
                                    </a>
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="NguyenVatLieus" asp-action="Index">
                                        <div class="nav-dropdown-icon module-amber">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Nguyên vật liệu</span>
                                            <span class="nav-dropdown-desc">Theo dõi nguyên liệu đầu vào</span>
                                        </div>
                                    </a>
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="PhanXuongs" asp-action="Index">
                                        <div class="nav-dropdown-icon module-teal">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Phân xưởng</span>
                                            <span class="nav-dropdown-desc">Quản lý phân xưởng sản xuất</span>
                                        </div>
                                    </a>
                                    
                                </div>
                            </div>
                        </li>
                        <li class="nav-dropdown-wrapper">
                            <button class="nav-link-item nav-dropdown-toggle" type="button" aria-expanded="false" aria-haspopup="true">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                                Chi phí
                                <svg class="dropdown-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </button>
                            <div class="nav-dropdown-menu">
                                <div class="nav-dropdown-inner">
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="ChiPhiNVL" asp-action="Index">
                                        <div class="nav-dropdown-icon module-amber">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Chi phí NVL</span>
                                            <span class="nav-dropdown-desc">Quản lý chi phí nguyên vật liệu</span>
                                        </div>
                                    </a>
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="ChiPhiNhanCong" asp-action="Index">
                                        <div class="nav-dropdown-icon module-blue">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Chi phí nhân công</span>
                                            <span class="nav-dropdown-desc">Theo dõi chi phí lao động trực tiếp</span>
                                        </div>
                                    </a>
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="ChiPhiSanXuatChung" asp-action="Index">
                                        <div class="nav-dropdown-icon module-teal">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Chi phí SX chung</span>
                                            <span class="nav-dropdown-desc">Các chi phí quản lý phân xưởng</span>
                                        </div>
                                    </a>
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="QuanLyPheLieu" asp-action="Index">
                                        <div class="nav-dropdown-icon" style="background-color: #fee2e2; color: #ef4444;">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"></polyline><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Quản lý phế liệu/SP hỏng</span>
                                            <span class="nav-dropdown-desc">Theo dõi phế liệu và sản phẩm hỏng</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </li>
                        <li>
                            <a class="nav-link-item" asp-area="" asp-controller="TinhGiaThanh" asp-action="Index">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <line x1="12" y1="1" x2="12" y2="23"></line>
                                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                                </svg>
                                Tính giá thành
                            </a>
                        </li>
                        <li class="nav-dropdown-wrapper">
                            <button class="nav-link-item nav-dropdown-toggle" type="button" aria-expanded="false" aria-haspopup="true">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                    <polyline points="14 2 14 8 20 8"></polyline>
                                    <line x1="16" y1="13" x2="8" y2="13"></line>
                                    <line x1="16" y1="17" x2="8" y2="17"></line>
                                    <polyline points="10 9 9 9 8 9"></polyline>
                                </svg>
                                Báo Cáo
                                <svg class="dropdown-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                    <polyline points="6 9 12 15 18 9"></polyline>
                                </svg>
                            </button>
                            <div class="nav-dropdown-menu">
                                <div class="nav-dropdown-inner">
                                    <a class="nav-dropdown-item" asp-area="" asp-controller="BaoCao" asp-action="BangTinhGiaThanhIndex">
                                        <div class="nav-dropdown-icon module-amber">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h18M3 9h18M3 15h18M3 21h18"></path></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Bảng Tính / Thẻ Giá Thành</span>
                                            <span class="nav-dropdown-desc">Chi tiết cấu thành giá của 1 sản phẩm</span>
                                        </div>
                                    </a>

                                    <a class="nav-dropdown-item" asp-area="" asp-controller="BaoCao" asp-action="TongHopChiPhiIndex">
                                        <div class="nav-dropdown-icon module-blue">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Tổng Hợp Chi Phí Sản Xuất</span>
                                            <span class="nav-dropdown-desc">Phân tích chi phí theo khoản mục, phân xưởng</span>
                                        </div>
                                    </a>

                                    <a class="nav-dropdown-item" asp-area="" asp-controller="BaoCao" asp-action="BienDongChiPhiIndex">
                                        <div class="nav-dropdown-icon module-teal">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"></polyline><polyline points="17 6 23 6 23 12"></polyline></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Phân Tích Biến Động (Variance)</span>
                                            <span class="nav-dropdown-desc">So sánh giá thành thực tế và định mức</span>
                                        </div>
                                    </a>

                                    <a class="nav-dropdown-item" asp-area="" asp-controller="BaoCao" asp-action="LaiLoGopIndex">
                                        <div class="nav-dropdown-icon" style="background-color: #dcfce7; color: #16a34a;">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"></rect><line x1="12" y1="9" x2="12" y2="15"></line><line x1="9" y1="12" x2="15" y2="12"></line></svg>
                                        </div>
                                        <div class="nav-dropdown-text">
                                            <span class="nav-dropdown-label">Lãi/Lỗ Gộp Theo Sản Phẩm</span>
                                            <span class="nav-dropdown-desc">Tích hợp doanh thu — xem biên lợi nhuận</span>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </li>
                        
                    </ul>

                    <div class="nav-right d-flex align-items-center gap-3">
                        <partial name="_LoginPartial" />
                        <button class="mobile-toggle d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu">
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
                        </button>
                    </div>
                </div>

                <div class="collapse" id="mobileMenu">
                    <ul class="mobile-nav-links">
                        <li><a asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="mobile-dropdown-group">
                            <button class="mobile-dropdown-toggle" type="button">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"></rect><rect x="14" y="3" width="7" height="7" rx="1"></rect><rect x="3" y="14" width="7" height="7" rx="1"></rect><rect x="14" y="14" width="7" height="7" rx="1"></rect></svg>
                                Danh mục
                                <svg class="mobile-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </button>
                            <ul class="mobile-sub-links">
                                <li><a asp-area="" asp-controller="SanPhams" asp-action="Index">Sản phẩm</a></li>
                                <li><a asp-area="" asp-controller="NguyenVatLieus" asp-action="Index">Nguyên vật liệu</a></li>
                                <li><a asp-area="" asp-controller="PhanXuongs" asp-action="Index">Phân xưởng</a></li>
                                <li><a asp-area="" asp-controller="DinhMucKyThuats" asp-action="Index">Định mức kỹ thuật</a></li>
                            </ul>
                        </li>
                        <li><a asp-area="" asp-controller="TinhGiaThanh" asp-action="Index">Tính giá thành</a></li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="main-footer">
        <div class="container">
            <div class="footer-inner">
                <div class="footer-brand">
                    <div class="brand-icon small">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg>
                    </div>
                    <span>KeToanGiaThanhSanPham</span>
                </div>
                <div class="footer-copy">&copy; 2026 — Ho Duc Nam Anh & Pham Duc Anh</div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="footer-link">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
