@model KeToanGiaThanhSanPham.Models.ViewModels.BaoCao.TongHopChiPhiViewModel

@{
    ViewData["Title"] = "Tổng Hợp Chi Phí Sản Xuất";
}

<h2>@ViewData["Title"]</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Phân tích theo khoản mục</h4>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Khoản mục</th>
                    <th class="text-end">Tổng (VND)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ByKhoanMuc)
                {
                    <tr>
                        <td>@item.Key</td>
                        <td class="text-end">@item.Total.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>Tổng</th>
                    <th class="text-end">@Model.TongCong.ToString("N0")</th>
                </tr>
            </tfoot>
        </table>
    </div>

    <div class="col-md-6">
        <h4>Phân tích theo phân xưởng</h4>
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Phân xưởng</th>
                    <th class="text-end">Tổng (VND)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ByPhanXuong)
                {
                    <tr>
                        <td>@item.Key</td>
                        <td class="text-end">@item.Total.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th>Tổng</th>
                    <th class="text-end">@Model.TongCong.ToString("N0")</th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>